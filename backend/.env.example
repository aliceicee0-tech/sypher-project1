# Server
PORT=4000
# Public URL of the frontend (used for CORS origin + OAuth redirect target).
CLIENT_URL=http://localhost:5173
# Set to "production" in deployments to enforce secure cookies & HSTS.
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/melodia

# Treblo API — MULTI-KEY FAILOVER
# When a generation fails on a key (out of credits, 401, 5xx, timeout), the
# backend automatically tries the next key, transparently. The failing key
# enters a 60s cooldown so it isn't retried immediately. Leave ALL empty to run
# in MOCK MODE (no real calls).
#
# RECOMMENDED for many keys: put them all in a single file (one per line) and
# point at it with TREBLO_KEYS_FILE. See .treblo-keys.example.
TREBLO_KEYS_FILE=
# Numbered vars still work (one per Treblo account) for small deployments.
TREBLO_API_KEY_1=
TREBLO_API_KEY_2=
TREBLO_API_KEY_3=
TREBLO_API_BASE_URL=https://api.treblo.com/v1
# Legacy single-key fallback (still read if set; ignored when _1/_2/_3 are set).
# TREBLO_API_KEY=

# Rate limiting for the paid generation endpoint (per user/IP).
GENERATE_RATE_MAX=10
GENERATE_RATE_WINDOW_MS=60000

# Freemium quota — maximum free generations per calendar month (free plan = 2/month).
FREE_MONTHLY_LIMIT=2

# Auth (JWT)
# REQUIRED — a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The server refuses to boot in production if this is missing or the default.
JWT_SECRET=change_me_to_a_long_random_string

# Google OAuth2 (from https://console.cloud.google.com/apis/credentials)
# See SETUP_GOOGLE.md for the full walkthrough.
# IMPORTANT: the redirect URI MUST use the FRONTEND origin (:5173) in dev so the
# OAuth state cookie + the JWT session cookie stay on the same origin the app
# calls from. Vite proxies /api/* to the backend on :4000 for you.
# Authorized redirect URI must be: http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# ── Optional (have sensible defaults; set for full functionality) ────────────
# Hard cap on total registered users (beta gate). 0 = no cap. Default: 100.
# MAX_USERS=100
# Admin emails (comma-separated) — may confirm orders, ban users, read /api/admin/*.
# ADMIN_EMAILS=you@example.com
# Manual payment instructions shown on the pricing page.
# MVOLA_NUMBER=
# BANK_IBAN=
# BANK_HOLDER=
# Expected number of Treblo keys (informational; flags a partially-loaded pool).
# TREBLO_EXPECTED_KEYS=100
