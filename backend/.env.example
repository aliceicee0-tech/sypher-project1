# Server
PORT=4000
# Public URL of the frontend (used for OAuth redirects and CORS).
CLIENT_URL=http://localhost:5173

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/musiblock

# Treblo API
# Leave TREBLO_API_KEY empty to run the backend in MOCK MODE (no real calls).
TREBLO_API_KEY=
TREBLO_API_BASE_URL=https://api.treblo.com/v1

# Auth (JWT)
# Use a long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Google OAuth2 (from https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must be: <backend>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
