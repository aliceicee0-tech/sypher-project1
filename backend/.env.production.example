# ─────────────────────────────────────────────────────────────────────────────
# Melodia backend — PRODUCTION environment template.
# Copy to ".env" (or your host's secret store) and fill in REAL values.
# NEVER commit the filled-in file. See PRODUCTION.md for the full checklist.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server / deployment ---
NODE_ENV=production
PORT=4000
# The PUBLIC origin of the frontend. CORS is locked to this and OAuth redirects
# back here. No trailing slash. e.g. https://melodia.example.com
CLIENT_URL=https://your-app-domain.example.com

# --- Database ---
# Managed MongoDB (MongoDB Atlas recommended). Use the SRV connection string.
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/melodia

# --- Treblo key pool (100 accounts) ---
# RECOMMENDED: point at a key file (one key per line). See .treblo-keys.example.
# Ship the file via your host's secret mount; it is git-ignored.
TREBLO_KEYS_FILE=/run/secrets/treblo-keys
# How many keys you expect to have loaded (informational; flags a partial pool).
TREBLO_EXPECTED_KEYS=100
# Fallback single key (optional — also read if the file/numbered vars are empty).
# TREBLO_API_KEY=
TREBLO_API_BASE_URL=https://api.treblo.com/v1

# --- Auth (JWT) ---
# REQUIRED in production — a long random string (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The server REFUSES TO BOOT in production if this is missing or the default.
JWT_SECRET=replace_with_64_hex_chars_minimum

# --- Google OAuth2 ---
# From Google Cloud Console (see SETUP_GOOGLE.md). The redirect URI MUST match
# the production frontend origin exactly, e.g.:
#   https://your-app-domain.example.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app-domain.example.com/api/auth/google/callback

# --- Capacity / beta gate ---
# Hard cap on total registered users. Once reached, new signups are refused
# with `?error=signup_closed` on /login. Set to 0 to disable the cap.
MAX_USERS=100

# --- Rate limiting ---
# Per-user/IP limits on the paid generation endpoint.
GENERATE_RATE_MAX=10
GENERATE_RATE_WINDOW_MS=60000

# --- Plans / quota ---
FREE_MONTHLY_LIMIT=2

# --- Manual payments (Mvola / bank transfer) ---
# Shown on the pricing page; required for orders to be meaningful.
MVOLA_NUMBER=
BANK_IBAN=
BANK_HOLDER=

# --- Admin access ---
# Comma-separated emails allowed to confirm orders, ban users, view /api/admin/*.
ADMIN_EMAILS=you@example.com

# --- Anti-abuse (account farming) ---
# Max NEW accounts per (device_id, ip) within the signup window.
ABUSE_MAX_SIGNUPS=5
# Safety net: max accounts per ip alone (catches cleared localStorage).
ABUSE_MAX_SIGNUPS_IP=15
# Rolling window length (ms) for the caps above.
ABUSE_SIGNUP_WINDOW_MS=600000
# Cookie name carrying the device UUID (set by the frontend).
ABUSE_DEVICE_COOKIE=melodia_device
