# Frontend environment variables.
#
# In DEVELOPMENT: leave this file empty / unset. Vite proxies "/api/*" to the
# local backend on :4000 (see vite.config.js), so everything is same-origin.
#
# In PRODUCTION (Vercel): the backend lives on a separate origin (Render), so
# you MUST point the frontend at it. Set this in Vercel → Settings → Environment
# Variables, then redeploy:
#
#   VITE_API_URL = https://melodia-backend.onrender.com/api
#
# (no trailing slash; the /api prefix is required). This value is baked into
# the build at compile time, so you must REBUILD after changing it.
#
# NOTE: VITE_ prefix is required — Vite only exposes vars prefixed with VITE_
# to the browser. Any other prefix is ignored and stays server-side only.

VITE_API_URL=
