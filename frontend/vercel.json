{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "description": "SPA fallback: all unknown routes serve index.html so React Router can handle them.",
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
